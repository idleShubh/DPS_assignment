{
  "name": "lagovia-train-tracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm run dev --workspace @lagovia/backend",
    "dev:frontend": "npm run dev --workspace @lagovia/frontend",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces"
  },
  "engines": {
    "node": ">=20"
  }
}
